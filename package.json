    "test:3": "mocha -r ts-node/register test/03-generics.test.ts",
    "test:4": "mocha -r ts-node/register test/04-advanced.test.ts",
    "test:5": "mocha -r ts-node/register test/05-async.test.ts",
    "test:6": "mocha -r ts-node/register test/06-analytics.test.ts"
